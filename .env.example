GEMINI_API_KEY=your-api-key-here
# Optional: override the default model (gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
# Optional: max agent iterations (default: 50)
# MAX_ITERATIONS=50
# Optional: output base folder for markdown reports
# In app-scoped mode, defaults to apps/<app>/<profile>/outputs.
# RESULTS_DIR=apps/example/local/outputs
# Optional: max concurrent role agents (default: 2)
# MAX_CONCURRENT_AGENTS=2
# Optional: app-scoped mode defaults
# APP_UNDER_TEST=example
# APP_PROFILE=local

# Preferred multi-role config: JSON file with roles.
# See apps/example/local/roles.example.json for format.
# ROLES_CONFIG_FILE=./apps/example/local/roles.json

# Env fallback for multi-role credentials (used only when ROLES_CONFIG_FILE is not set):
# ROLES=admin,member
# ROLE_ADMIN_EMAIL=admin@example.com
# ROLE_ADMIN_PASSWORD=admin-password
# ROLE_ADMIN_CONTEXT_FILE=./apps/example/local/admin-context.md
# ROLE_MEMBER_USERNAME=member01
# ROLE_MEMBER_PASSWORD=member-password
# ROLE_MEMBER_CONTEXT_FILE=./apps/example/local/member-context.md

# Legacy single-role fallback (used only when ROLES and ROLES_CONFIG_FILE are not set):
# APP_CONTEXT_FILE=./apps/example/local/app-context.md
# TEST_USER_EMAIL=tester@example.com
# TEST_USERNAME=test-user
# TEST_USER_PASSWORD=your-password
